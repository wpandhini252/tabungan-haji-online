              }
            }
          ]
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"passwordBaru123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user", "{{userId}}"]
            },
            "description": "Update parsial (`username` dan/atau `password`). Minimal satu field. Jika `password` diisi, akan di-hash ulang. Aturan validasi field sama dengan Create.\n\nTest script menyimpan password baru ke variable agar request Login berikutnya tetap konsisten."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Update sukses tanpa bocor password', () => {",
                  "    pm.expect(j.message).to.eql('User berhasil diupdate');",
                  "    pm.expect(j.data).to.not.have.property('password');",
                  "});",
                  "pm.collectionVariables.set('userPassword', 'passwordBaru123');"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user", "{{userId}}"]
            },
            "description": "Hapus user by UUID. 204 kalau sukses (no body), 404 kalau tidak ada."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));",
                  "pm.collectionVariables.set('userId', '');",
                  "pm.collectionVariables.set('userUsername', '');",
                  "pm.collectionVariables.set('userPassword', '');"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/user/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user", "logout"]
            },
            "description": "Logout: me-revoke token JWT saat ini di server (masuk denylist sampai kedaluwarsa). Wajib menyertakan Bearer token. Sukses 200. **Jalankan paling akhir** — setelah ini token tidak berlaku lagi dan variable `token` dikosongkan, sehingga request terproteksi lain akan 401 sampai login ulang."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Logout berhasil', () => pm.expect(j.message).to.eql('Logout berhasil'));",
                  "pm.collectionVariables.set('token', '');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tabungan",
      "item": [
        {
          "name": "Create Tabungan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nasabahId\": \"{{nasabahId}}\",\n  \"saldoAwal\": 500000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tabungan",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tabungan"]
            },
            "description": "Buka rekening tabungan haji baru. `nomorRekening` opsional (auto-generate 13 digit kalau kosong). `saldoAwal` opsional (default 0).\n\n**Body fields:**\n- `nasabahId` (string UUID, wajib) — referensi nasabah\n- `nomorRekening` (string 10-20 digit, opsional)\n- `saldoAwal` (integer ≥ 0, opsional)\n\n**Status codes:** 201 created • 400 validasi • 409 nomorRekening duplikat • 400 INVALID_REFERENCE kalau nasabahId tidak ada."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('Response punya data.id & nomorRekening', () => {",
                  "    pm.expect(j.data).to.have.property('id');",
